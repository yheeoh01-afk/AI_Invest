# Streamlit Cloud → App settings → Secrets 에 아래 내용을 넣으세요.

# 로그인 계정: 여러 명이면 쉼표로 추가
USERS = '{"admin":"1234", "younghee":"원하는비밀번호"}'

# 네이버 뉴스 API
NAVER_CLIENT_ID = "네이버_client_id"
NAVER_CLIENT_SECRET = "네이버_client_secret"

# Supabase REST API
# Project URL 예: https://xxxx.supabase.co
SUPABASE_URL = "https://프로젝트ID.supabase.co"
SUPABASE_ANON_KEY = "Supabase_publishable_or_anon_key"
